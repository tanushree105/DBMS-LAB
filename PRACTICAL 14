1. create a table emp2 with fields empno as int, name as charactor, cateagory as int(take only 3 catagories i.e., 1, 2 & 3)

CREATE TABLE emp2 (
    empno INT PRIMARY KEY,
    name VARCHAR(50),
    category INT CHECK (category IN (1, 2, 3))
);

