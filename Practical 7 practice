while loop
syntax:
	begin
	initialization st;
	while cond loop
	True st,
	increment/decrement
end loop;
end;

CREATE OR REPLACE PROCEDURE SumF10 
AS
    i NUMBER := 1;
    s NUMBER := 0;
BEGIN
    WHILE i <= 10 LOOP
        s := s + i;
        i := i + 1;
    END LOOP;
    DBMS_OUTPUT.PUT_LINE('Result of sum: ' || s);
END;
/
