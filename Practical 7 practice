(1-N num loop)
CREATE OR REPLACE PROCEDURE SumFN
AS
    i NUMBER := 1;
    n NUMBER := 10;
    s NUMBER := 0;
BEGIN
    WHILE i <= n LOOP
        s := s + i;
        i := i + 1;
    END LOOP;
    DBMS_OUTPUT.PUT_LINE('Result of sum: ' || s);
END;
/

