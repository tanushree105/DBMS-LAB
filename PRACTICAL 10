CREATE OR REPLACE PROCEDURE check_marks (m1 IN NUMBER, m2 IN NUMBER, m3 IN NUMBER)
AS
BEGIN
    -- BEGIN marks checking block
    IF m1 >= 35 AND m2 >= 35 AND m3 >= 35 THEN
        -- PASS case
        DBMS_OUTPUT.PUT_LINE('PASS: Marks are ' || m1 || ', ' || m2 || ', ' || m3);
    ELSE
        -- FAIL case
        DBMS_OUTPUT.PUT_LINE('FAIL: Marks are ' || m1 || ', ' || m2 || ', ' || m3);
    END IF;
END check_marks;
/

