4. design a trigger for insertion or updation for the following
	
(a) if category is 1 then salary should be more than 10000
(b) if category is 2 then salary should be more than 20000
(c) if category is 3 then salary should be more than 30000

CREATE OR REPLACE TRIGGER trg_salary_check_emp2
BEFORE INSERT OR UPDATE ON EMP2
FOR EACH ROW
BEGIN
    IF :NEW.category = 1 AND :NEW.salary <= 10000 THEN
        DBMS_OUTPUT.PUT_LINE('Warning: Salary should be more than 10000 for category 1');
    ELSIF :NEW.category = 2 AND :NEW.salary <= 20000 THEN
        DBMS_OUTPUT.PUT_LINE('Warning: Salary should be more than 20000 for category 2');
    ELSIF :NEW.category = 3 AND :NEW.salary <= 30000 THEN
        DBMS_OUTPUT.PUT_LINE('Warning: Salary should be more than 30000 for category 3');
    ELSE
        DBMS_OUTPUT.PUT_LINE('Category OK or salary is sufficient.');
    END IF;
END;
/

Trigger created.

