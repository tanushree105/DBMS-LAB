CREATE OR REPLACE PROCEDURE first_exception (n IN NUMBER)
AS
    vname   emp_new.emp_name%TYPE;
    vsalary emp_new.salary%TYPE;
BEGIN
    -- Try to select the employee
    SELECT emp_name, salary
    INTO vname, vsalary
    FROM emp_new
    WHERE emp_id = n;

    -- Print the results
    DBMS_OUTPUT.PUT_LINE('Name   = ' || vname);
    DBMS_OUTPUT.PUT_LINE('Salary = ' || vsalary);

EXCEPTION
    -- Handle case when no employee is found
    WHEN NO_DATA_FOUND THEN
        DBMS_OUTPUT.PUT_LINE('Employee with emp_id = ' || n || ' not found');
END first_exception;
/

