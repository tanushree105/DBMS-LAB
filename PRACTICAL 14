6. design a trigger to stop insertion or updation in the table for the days like sat or sun of any date (for practice purpose take the day as 'tue')


create or replace trigger trg_block_day_emp2
before insert or update on emp2
for each row
begin
    if to_char(sysdate, 'dy', 'nls_date_language=english') = 'tue' then
        dbms_output.put_line('warning: insert/update happening on tuesday!');
    else
        dbms_output.put_line('insert/update allowed today.');
    end if;
end;
/

Trigger created.

