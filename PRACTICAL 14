2. design a trigger for insertion or updation a new record in capital letter only
(HINT: name=upper(name)

CREATE OR REPLACE TRIGGER trg_emp2_caps
BEFORE INSERT OR UPDATE ON emp2
FOR EACH ROW
BEGIN
    :NEW.name := UPPER(:NEW.name);
END;
/

