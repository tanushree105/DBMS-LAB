(FOR LOOP) == 1-N num;
CREATE OR REPLACE PROCEDURE SumFN
AS
    n NUMBER := 10;
    s NUMBER := 0;
BEGIN
    FOR i IN 1..n LOOP
        s := s + i;
    END LOOP;
    DBMS_OUTPUT.PUT_LINE('Result of sum: ' || s);
END;
/


